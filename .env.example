# ─── Zoho CRM (Distribuidor de Leads) ───────────────────────────────────────
# Si estas 3 están presentes, las rutas /api/zoho/* operan en REAL; si faltan,
# caen a MOCK (el software sigue vivo). Reutilizar el connected-app de la org
# Windmar (US .com, org 699641359) con los scopes acordados.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Data center y org (defaults correctos para Windmar)
ZOHO_DC=com
ZOHO_ORG_ID=699641359

# API names CONFIRMADOS contra la org real (2026-06-22):
ZOHO_FIELD_FECHA=Presenter_Appointment
ZOHO_FIELD_TEAM=Team_Assitance
ZOHO_ESTADO_CITA=Cita Coordinada

# Scopes a pedir en el connected-app (referencia):
# ZohoCRM.modules.leads.READ,ZohoCRM.modules.leads.CREATE,ZohoCRM.modules.leads.UPDATE,
# ZohoCRM.modules.deals.READ,ZohoCRM.modules.notes.ALL,ZohoCRM.modules.attachments.CREATE,
# ZohoCRM.modules.custom.READ,ZohoCRM.users.READ,ZohoCRM.settings.fields.READ,ZohoCRM.coql.READ
